generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MENTOR
  ASSISTANT
  STUDENT
}

enum CourseLevel {
  BEGINNER
  PRE_INTERMEDIATE
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
}

enum PaidVia {
  PAYME
  CLICK
  CASH
}

enum HomeworkSubStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ExamAnswer {
  variantA
  variantB
  variantC
  variantD
}

model User {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  password  String
  role      UserRole @default(STUDENT)
  fullName  String
  image     String?
  publicId  String?
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  // Munosabatlar
  mentorProfile        MentorProfile?
  assignedCourses      AssignedCourse[]
  courses              Course[]
  lessonViews          LessonView[]
  purchasedCourses     PurchasedCourse[]
  ratings              Rating[]
  homeworkSubmissions  HomeworkSubmission[]
  examResults          ExamResult[]
  studentExamQuestions StudentExamQuestion[]
  questions            Question[]
  questionAnswers      QuestionAnswer[]
  lastActivities       LastActivity[]
}

model MentorProfile {
  id         Int     @id @default(autoincrement())
  about      String?
  job        String?
  experience Int
  telegram   String?
  instagram  String?
  linkedin   String?
  facebook   String?
  github     String?
  website    String?

  // User bilan bog'lanish
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CourseCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  courses   Course[]
}

model Course {
  id             Int               @id @default(autoincrement())
  name           String
  about          String            @db.Text
  price          Decimal           @db.Decimal(10, 2)
  banner         String?
  bannerPublicId String?
  introVideo     String?
  videoPublicId  String?
  level          CourseLevel
  published      Boolean           @default(false)
  isDeleted      Boolean           @default(false)
  assignedBy     AssignedCourse[]
  sections       SectionLesson[]
  purchasedBy    PurchasedCourse[]
  ratings        Rating[]
  questions      Question[]
  lastActivities LastActivity[]

  // Bog'lanishlar (Foreign Keys)
  categoryId Int
  category   CourseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  mentorId Int
  mentor   User @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssignedCourse {
  userId   Int
  courseId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, courseId])
}

model SectionLesson {
  id        Int      @id @default(autoincrement())
  name      String
  courseId  Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  createdAt DateTime @default(now())

  exams          Exam[]
  examResults    ExamResult[]
  studentAnswers StudentExamQuestion[]
  lastActivities LastActivity[]
}

model Lesson {
  id        Int           @id @default(autoincrement())
  name      String
  about     String        @db.Text
  video     String
  publicId  String?
  sectionId Int
  section   SectionLesson @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  views          LessonView[]
  files          LessonFile[]
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())
  homework       Homework?
  lastActivities LastActivity[]
}

model LessonView {
  lessonId Int
  userId   Int
  view     Boolean @default(false)
  lesson   Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([lessonId, userId])
}

model LessonFile {
  id        Int      @id @default(autoincrement())
  file      String
  publicId  String?
  note      String?
  lessonId  Int
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PurchasedCourse {
  id          Int      @id @default(autoincrement())
  courseId    Int
  userId      Int
  amount      Decimal  @db.Decimal(10, 2)
  paidVia     PaidVia
  purchasedAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Rating {
  id        Int      @id @default(autoincrement())
  rate      Int
  comment   String   @db.Text
  courseId  Int
  userId    Int
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Homework {
  id        Int      @id @default(autoincrement())
  task      String   @db.Text
  file      String?
  publicId  String?
  lessonId  Int      @unique
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  submissions HomeworkSubmission[]
  updatedAt   DateTime             @updatedAt
  createdAt   DateTime             @default(now())
}

model HomeworkSubmission {
  id        Int               @id @default(autoincrement())
  text      String?           @db.Text
  file      String?
  publicId  String?
  reason    String?           @db.Text
  status    HomeworkSubStatus @default(PENDING)
  updatedAt DateTime          @updatedAt
  createdAt DateTime          @default(now())

  homeworkId Int
  userId     Int
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exam {
  id              Int           @id @default(autoincrement())
  question        String        @db.Text
  variantA        String        @db.Text
  variantB        String        @db.Text
  variantC        String        @db.Text
  variantD        String        @db.Text
  answer          ExamAnswer
  sectionLessonId Int
  section         SectionLesson @relation(fields: [sectionLessonId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  studentAnswers StudentExamQuestion[]
}

model StudentExamQuestion {
  id              Int           @id @default(autoincrement())
  examId          Int
  userId          Int
  answer          ExamAnswer
  isCorrect       Boolean
  sectionLessonId Int
  createdAt       DateTime      @default(now())
  exam            Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  section         SectionLesson @relation(fields: [sectionLessonId], references: [id], onDelete: Cascade)
}

model ExamResult {
  id              Int           @id @default(autoincrement())
  sectionLessonId Int
  userId          Int
  passed          Boolean
  corrects        Int
  wrongs          Int
  createdAt       DateTime      @default(now())
  section         SectionLesson @relation(fields: [sectionLessonId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Question {
  id        Int             @id @default(autoincrement())
  userId    Int
  courseId  Int
  text      String          @db.Text
  file      String?
  publicId  String?
  read      Boolean         @default(false)
  readAt    DateTime?
  updatedAt DateTime        @updatedAt
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  answer    QuestionAnswer?
}

model QuestionAnswer {
  id         Int      @id @default(autoincrement())
  questionId Int      @unique
  userId     Int
  text       String   @db.Text
  file       String?
  publicId   String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LastActivity {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  sectionId Int?
  lessonId  Int?
  url       String?
  updatedAt DateTime @updatedAt @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserToLastActivity")
  course  Course         @relation(fields: [courseId], references: [id], name: "CourseToLastActivity")
  section SectionLesson? @relation(fields: [sectionId], references: [id], name: "SectionToLastActivity")
  lesson  Lesson?        @relation(fields: [lessonId], references: [id], name: "LessonToLastActivity")

  @@unique([userId, courseId])
}
